<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- WeighingSession: post-auction weighing per bid. Aligned with WeighingPage.tsx mkt_weighing_sessions. -->
    <changeSet id="20260228160000-1" author="mercotrace">
        <createTable tableName="weighing_session">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="trader_id" type="bigint">
                <constraints nullable="true"/>
            </column>
            <column name="session_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="lot_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="bid_number" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="buyer_mark" type="varchar(50)"/>
            <column name="buyer_name" type="varchar(200)"/>
            <column name="seller_name" type="varchar(200)"/>
            <column name="lot_name" type="varchar(255)"/>
            <column name="total_bags" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="original_weight" type="numeric(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="net_weight" type="numeric(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="manual_entry" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deductions" type="numeric(19,4)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="govt_deduction_applied" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="round_off_applied" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="bag_weights_json" type="text"/>
            <column name="created_by" type="varchar(50)"/>
            <column name="created_date" type="${datetimeType}"/>
            <column name="last_modified_by" type="varchar(50)"/>
            <column name="last_modified_date" type="${datetimeType}"/>
        </createTable>
        <createIndex tableName="weighing_session" indexName="idx_weighing_session_trader">
            <column name="trader_id"/>
        </createIndex>
        <createIndex tableName="weighing_session" indexName="idx_weighing_session_bid">
            <column name="bid_number"/>
        </createIndex>
        <createIndex tableName="weighing_session" indexName="idx_weighing_session_lot">
            <column name="lot_id"/>
        </createIndex>
        <createIndex tableName="weighing_session" indexName="idx_weighing_session_session_id">
            <column name="session_id"/>
        </createIndex>
    </changeSet>

    <!-- PrintLog: audit of print events. Aligned with BillingPage/WeighingPage mkt_print_logs. -->
    <changeSet id="20260228160000-2" author="mercotrace">
        <createTable tableName="print_log">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="trader_id" type="bigint">
                <constraints nullable="true"/>
            </column>
            <column name="reference_type" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="reference_id" type="varchar(64)"/>
            <column name="print_type" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="printed_at" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(50)"/>
            <column name="created_date" type="${datetimeType}"/>
            <column name="last_modified_by" type="varchar(50)"/>
            <column name="last_modified_date" type="${datetimeType}"/>
        </createTable>
        <createIndex tableName="print_log" indexName="idx_print_log_trader">
            <column name="trader_id"/>
        </createIndex>
        <createIndex tableName="print_log" indexName="idx_print_log_printed_at">
            <column name="printed_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
